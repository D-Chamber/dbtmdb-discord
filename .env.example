# Discord bot token — from discord.com/developers/applications > Bot > Reset Token
DISCORD_TOKEN=your_discord_bot_token_here

# TMDB API Read Access Token (the long JWT starting with eyJ...)
# Found at themoviedb.org > Settings > API > API Read Access Token
# NOTE: this is NOT the short API Key — it must be the Read Access Token
TMDB_ACCESS_TOKEN=your_tmdb_read_access_token_here

# How long to cache TMDB responses in memory (default: 15 minutes)
CACHE_DURATION_MINUTES=15

# Maximum number of results shown per page (default: 5, max Discord allows: 5 buttons per row)
MAX_RESULTS=5

# Log level: info | debug | warn | error (default: info)
LOG_LEVEL=info
